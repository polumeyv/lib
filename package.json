{
	"name": "@polumeyv/lib",
	"version": "0.9.0",
	"description": "Effect-based infrastructure + auth library for Bun applications",
	"license": "MIT",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/polumeyv/lib.git"
	},
	"keywords": [
		"effect",
		"bun",
		"postgres",
		"redis",
		"stripe",
		"auth",
		"jwt",
		"otp",
		"oauth"
	],
	"scripts": {
		"check": "tsc --noEmit",
		"generate-jwt-keys": "bun bin/generate-jwt-keys.mjs",
		"release": "npx changelogen --release --push"
	},
	"bin": {
		"generate-jwt-keys": "./bin/generate-jwt-keys.mjs"
	},
	"type": "module",
	"files": [
		"src",
		"bin"
	],
	"exports": {
		"./error": {
			"types": "./src/error.ts",
			"default": "./src/error.ts"
		},
		"./server": {
			"types": "./src/server/index.ts",
			"default": "./src/server/index.ts"
		},
		"./server/live": {
			"types": "./src/server/live/index.ts",
			"default": "./src/server/live/index.ts"
		},
		"./schemas": {
			"types": "./src/schemas/index.ts",
			"default": "./src/schemas/index.ts"
		},
		"./public": {
			"types": "./src/public/index.ts",
			"default": "./src/public/index.ts"
		}
	},
	"peerDependencies": {
		"effect": "4.0.0-beta.70",
		"@internationalized/date": "3.12.1"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.0",
		"cookie": "^1.1.1",
		"jose": "^6.2.2",
		"oauth4webapi": "^3.8.6",
		"stripe": "^22.1.1"
	}
}
