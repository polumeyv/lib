{
	"name": "@polumeyv/lib",
	"version": "0.11.0",
	"description": "Effect-based infrastructure + auth library for Bun applications",
	"license": "MIT",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/polumeyv/lib.git"
	},
	"keywords": [
		"effect",
		"bun",
		"postgres",
		"redis",
		"stripe",
		"auth",
		"jwt",
		"otp",
		"oauth"
	],
	"scripts": {
		"check": "tsc --noEmit",
		"generate-jwt-keys": "bun bin/generate-jwt-keys.mjs",
		"release": "npx changelogen --release --push"
	},
	"bin": {
		"generate-jwt-keys": "./bin/generate-jwt-keys.mjs"
	},
	"type": "module",
	"sideEffects": false,
	"files": [
		"src",
		"bin"
	],
	"exports": {
		"./error": {
			"types": "./src/error.ts",
			"default": "./src/error.ts"
		},
		"./server": {
			"types": "./src/server/index.ts",
			"default": "./src/server/index.ts"
		},
		"./server/live": {
			"types": "./src/server/live/index.ts",
			"default": "./src/server/live/index.ts"
		},
		"./server/postgres": {
			"types": "./src/server/postgres.ts",
			"default": "./src/server/postgres.ts"
		},
		"./server/redis": {
			"types": "./src/server/redis.ts",
			"default": "./src/server/redis.ts"
		},
		"./server/stripe": {
			"types": "./src/server/stripe.ts",
			"default": "./src/server/stripe.ts"
		},
		"./server/idp-client": {
			"types": "./src/server/idp-client.ts",
			"default": "./src/server/idp-client.ts"
		},
		"./server/user.repo": {
			"types": "./src/server/user.repo.ts",
			"default": "./src/server/user.repo.ts"
		},
		"./server/crypto": {
			"types": "./src/server/crypto.ts",
			"default": "./src/server/crypto.ts"
		},
		"./server/alert": {
			"types": "./src/server/alert.ts",
			"default": "./src/server/alert.ts"
		},
		"./server/shutdown": {
			"types": "./src/server/shutdown.ts",
			"default": "./src/server/shutdown.ts"
		},
		"./server/sms": {
			"types": "./src/server/sms.ts",
			"default": "./src/server/sms.ts"
		},
		"./server/customer": {
			"types": "./src/server/customer.ts",
			"default": "./src/server/customer.ts"
		},
		"./server/error-reporter": {
			"types": "./src/server/error-reporter.ts",
			"default": "./src/server/error-reporter.ts"
		},
		"./schemas": {
			"types": "./src/schemas/index.ts",
			"default": "./src/schemas/index.ts"
		},
		"./schemas/primitives": {
			"types": "./src/schemas/primitives.ts",
			"default": "./src/schemas/primitives.ts"
		},
		"./schemas/tables": {
			"types": "./src/schemas/tables.ts",
			"default": "./src/schemas/tables.ts"
		},
		"./schemas/projections": {
			"types": "./src/schemas/projections.ts",
			"default": "./src/schemas/projections.ts"
		},
		"./schemas/composites": {
			"types": "./src/schemas/composites.ts",
			"default": "./src/schemas/composites.ts"
		},
		"./public": {
			"types": "./src/public/index.ts",
			"default": "./src/public/index.ts"
		}
	},
	"peerDependencies": {
		"effect": "4.0.0-beta.78",
		"@internationalized/date": "3.12.1"
	},
	"dependencies": {
		"@aws-sdk/client-sesv2": "^3.1062.0",
		"@internationalized/date": "^3.12.0",
		"cookie": "^1.1.1",
		"jose": "^6.2.2",
		"oauth4webapi": "^3.8.6",
		"stripe": "^22.2.0"
	}
}
